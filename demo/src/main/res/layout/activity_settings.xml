<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:theme="@style/AppTheme.AppBarOverlay"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorPrimary"
            app:navigationIcon="@drawable/ic_arrow_back_white_24dp"
            app:popupTheme="@style/AppTheme.PopupOverlay"
            app:title="@string/settings"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- ─── Primary Network ────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.05"
                android:text="🌐  Primary Ad Network"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingVertical="8dp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Backup Network ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.05"
                android:text="🔄  Backup Ad Network"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_backup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingVertical="8dp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Format Preferences ────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.05"
                android:text="⚙️  Ad Format Preferences"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="4dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_all_ads"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="🚀  Enable All Ads (Master Toggle)"
                        android:textStyle="bold"
                        app:thumbTint="@color/colorPrimary" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_dark_mode"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="🌙  Dark Mode" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_app_open_ad"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="📱  App Open Ad on Resume" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_banner_ad"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="🖼  Banner Ads" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_interstitial_ad"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="🎬  Interstitial Ads" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_native_ad"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="🎨  Native Ads" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_rewarded_ad"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="🎁  Rewarded Ads" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_rewarded_interstitial_ad"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="🎬🎁  Rewarded Interstitial Ads" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <!-- Interstitial Interval stepper -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="⏱  Interstitial Interval"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_interval_minus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            android:text="@string/minus"
                            android:textSize="18sp"
                            app:cornerRadius="8dp" />

                        <TextView
                            android:id="@+id/tv_interval_value"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/three"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_interval_plus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            android:text="@string/plus"
                            android:textSize="18sp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ─── SDK Core Settings ──────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.05"
                android:text="@string/sdk_core_settings"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="4dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_test_mode"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="Test Mode"
                        app:thumbTint="@color/colorPrimary" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_aggressive_preload"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="@string/aggressive_preload" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_debug_hud"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="@string/debug_hud" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />


                    <!-- Rewarded Interval stepper -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/rewarded_interval"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_rewarded_interval_minus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            android:text="@string/minus"
                            android:textSize="18sp"
                            app:cornerRadius="8dp" />

                        <TextView
                            android:id="@+id/tv_rewarded_interval_value"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_rewarded_interval_plus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            android:text="@string/plus"
                            android:textSize="18sp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:alpha="0.3"
                        android:background="?attr/colorOutline" />

                    <!-- Ad Response Timeout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/ad_timeout"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_ad_timeout_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingEnd="12dp"
                            android:text="3500"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ad_timeout_minus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            android:text="@string/minus"
                            android:textSize="18sp"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ad_timeout_plus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            android:text="@string/plus"
                            android:textSize="18sp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ─── House Ads ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.05"
                android:text="🏠  House Ads (Zero-Fill Fallback)"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="4dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_house_ad"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="20dp"
                        android:text="Enable House Ads" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="1.4"
                        android:paddingHorizontal="20dp"
                        android:paddingBottom="16dp"
                        android:text="@string/house_ads_desc"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Privacy ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.05"
                android:text="🔒  Privacy"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gdpr"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔑  Manage GDPR Consent"
                android:textSize="14sp"
                app:cornerRadius="14dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
