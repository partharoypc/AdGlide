<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorPrimary"
    android:gravity="center">

    <!-- Glow Circle behind logo -->
    <FrameLayout
        android:id="@+id/logo_container"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_splash_glow">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@null"
            android:scaleType="fitCenter" />

    </FrameLayout>

    <!-- Brand name -->
    <TextView
        android:id="@+id/brand_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AdGlide"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="32dp"
        android:letterSpacing="0.05"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Premium Ad Mediation SDK"
        android:textSize="15sp"
        android:textColor="#B0D0BCFF"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="8dp"
        android:letterSpacing="0.08"/>

    <!-- Loading dots indicator -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="64dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_dot_active"/>

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_dot_inactive"/>

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_dot_inactive"/>

    </LinearLayout>

    <!-- Version / copyright -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.6.0 · © 2026 AdGlide"
        android:textSize="12sp"
        android:textColor="#60FFFFFF"
        android:layout_marginTop="24dp"/>

</LinearLayout>
