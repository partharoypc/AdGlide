<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adglide_color_debug_background"
    android:orientation="vertical"
    android:padding="16dp"
    tools:ignore="Overdraw,HardcodedText,SetTextI18n">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="AdGlide SDK Debugger"
        android:textColor="@color/adglide_color_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- SDK Config Section -->
    <TextView
        android:id="@+id/config_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@color/adglide_color_debug_surface"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:text="Loading configuration..."
        android:textColor="@color/adglide_color_text_secondary"
        android:textSize="13sp" />

    <!-- Waterfall Status Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="Waterfall Status"
        android:textColor="@color/adglide_color_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="12dp"
        android:background="@color/adglide_color_debug_surface"
        android:padding="6dp">

        <TextView
            android:id="@+id/waterfall_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="— No ad requests yet —"
            android:textColor="@color/adglide_color_debug_logs"
            android:textSize="11sp" />
    </ScrollView>

    <!-- Performance Logs Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="Performance Logs"
        android:textColor="@color/adglide_color_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/adglide_color_debug_surface"
        android:padding="8dp">

        <TextView
            android:id="@+id/logs_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/adglide_color_debug_logs"
            android:textSize="12sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        style="?android:attr/buttonBarStyle">

        <Button
            android:id="@+id/refresh_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Refresh"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/clear_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Clear"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btn_test_ad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Test Ad"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btn_close_hud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close"
            style="?android:attr/buttonBarButtonStyle" />
    </LinearLayout>

</LinearLayout>
