<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adglide_color_debug_background"
    android:orientation="vertical"
    android:padding="16dp"
    tools:ignore="Overdraw,HardcodedText,SetTextI18n">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="AdGlide SDK Debugger"
        android:textColor="@color/adglide_color_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/config_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@color/adglide_color_debug_surface"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:text="Loading configuration..."
        android:textColor="@color/adglide_color_text_secondary"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Performance Logs"
        android:textColor="@color/adglide_color_text_primary"
        android:textSize="18sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/adglide_color_debug_surface"
        android:padding="8dp">

        <TextView
            android:id="@+id/logs_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/adglide_color_debug_logs"
            android:textSize="12sp" />
    </ScrollView>

    <Button
        android:id="@+id/refresh_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Refresh Logs" />

</LinearLayout>
