<?xml version='1.0' encoding='utf-8'?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/start_app_unit"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        app:cardBackgroundColor="@color/adglide_color_background"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/adglide_color_outline"
        app:strokeWidth="1.5dp">

        <LinearLayout
            android:id="@+id/start_app_native_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/adglide_video_padding_medium"
                android:layout_marginTop="@dimen/adglide_video_padding_medium"
                android:layout_marginEnd="@dimen/adglide_video_padding_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/adglide_video_padding_medium"
                    android:layout_toStartOf="@+id/ad_options_view"
                    android:orientation="horizontal">

                    <include layout="@layout/adglide_view_native_ad_label" />


                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ad_options_view"
                    android:layout_width="@dimen/adglide_ad_options_size"
                    android:layout_height="@dimen/adglide_ad_options_size"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:visibility="gone" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/adglide_video_padding_medium"
                android:layout_marginTop="@dimen/adglide_item_post_padding_small"
                android:layout_marginEnd="@dimen/adglide_video_padding_medium"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="@dimen/adglide_video_thumbnail_width"
                    android:layout_height="@dimen/adglide_video_thumbnail_height"
                    android:layout_marginTop="@dimen/adglide_video_padding_small"
                    app:cardCornerRadius="@dimen/adglide_corner_radius"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/start_app_native_icon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/adglide_img_content_description"
                        android:scaleType="centerCrop" />

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/adglide_item_post_padding_medium"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/start_app_native_title"
                        style="@style/AdGlide.Headline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="start"
                        android:maxLines="1"
                        android:text="" />

                    <TextView
                        android:id="@+id/start_app_native_description"
                        style="@style/AdGlide.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="" />

                    <RatingBar
                        android:id="@+id/rating_bar"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/adglide_spacing_tiny"
                        android:numStars="5"
                        android:rating="4.5"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/adglide_item_post_padding_small">

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintDimensionRatio="H,16:9"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/start_app_native_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/adglide_img_content_description"
                        android:scaleType="centerCrop" />

                </RelativeLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/start_app_native_button"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/adglide_video_cta_button_height"
                android:layout_margin="@dimen/adglide_video_padding_medium"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="true"
                android:textColor="@color/adglide_color_cta_text"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@color/adglide_color_cta_background"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
</LinearLayout>